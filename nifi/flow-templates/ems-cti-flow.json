        "type": "OUTPUT_PORT",
        "concurrentlySchedulableTaskCount": 2,
        "schedulingStrategy": "TIMER_DRIVEN",
        "position": { "x": 200, "y": 1400 }
      },
      {
        "identifier": "port-low-command-output",
        "instanceIdentifier": "port-low-command-output-inst",
        "name": "low-command-output",
