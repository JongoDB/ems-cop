        "type": "OUTPUT_PORT",
        "concurrentlySchedulableTaskCount": 2,
        "schedulingStrategy": "TIMER_DRIVEN",
        "position": { "x": 600, "y": 1400 }
      }
    ],
    "connections": [
      {
        "identifier": "conn-low-input-to-size-filter",
        "instanceIdentifier": "conn-low-input-to-size-filter-inst",
