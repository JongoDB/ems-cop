# EMS-COP Low-Side Enclave — Environment Configuration
# Copy to .env.low and fill in values before running:
#   docker compose -f docker-compose.low.yml --env-file .env.low up -d

# ════════════════════════════════════════════
#  ENCLAVE IDENTITY
# ════════════════════════════════════════════

# Enclave classification level (low = UNCLASSIFIED / tactical)
# Set automatically in x-common-env-low, but available for override
# ENCLAVE=low

# ════════════════════════════════════════════
#  REQUIRED
# ════════════════════════════════════════════

# PostgreSQL
POSTGRES_PASSWORD=ems_dev_password_low_change_me

# JWT signing secret (generate with: openssl rand -hex 32)
# IMPORTANT: Low and high enclaves should use DIFFERENT JWT secrets
JWT_SECRET=ems_jwt_secret_low_change_me_in_production

# ════════════════════════════════════════════
#  INFRASTRUCTURE
# ════════════════════════════════════════════

# Redis
REDIS_PASSWORD=ems_redis_low_password

# ClickHouse
CLICKHOUSE_PASSWORD=ems_audit_low_password

# MinIO (S3-compatible object storage)
MINIO_ACCESS_KEY=ems_minio_low_admin
MINIO_SECRET_KEY=ems_minio_secret_low_change_me

# ════════════════════════════════════════════
#  NETWORK PORTS (host mappings — low side)
# ════════════════════════════════════════════

# Traefik (low side)
EMS_HTTP_PORT=18080
EMS_HTTPS_PORT=18443
TRAEFIK_DASHBOARD_PORT=18081

# PostgreSQL dev access
PG_HOST_PORT=15432

# ClickHouse dev access
CH_HTTP_PORT=18123
CH_NATIVE_PORT=19000

# Redis dev access
REDIS_HOST_PORT=16379

# NATS dev access
NATS_HOST_PORT=14222
NATS_MON_PORT=18222

# MinIO
MINIO_API_PORT=19090
MINIO_CONSOLE_PORT=19001

# CORS allowed origins (must match Traefik host port)
ALLOWED_ORIGINS=http://localhost:18080

# ════════════════════════════════════════════
#  NOTIFICATIONS (optional)
# ════════════════════════════════════════════

# SMTP for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ems-cop-low.local

# Jira integration
JIRA_DEFAULT_URL=
JIRA_DEFAULT_EMAIL=
JIRA_DEFAULT_TOKEN=

# ════════════════════════════════════════════
#  SLIVER C2 (low side only)
# ════════════════════════════════════════════

# Sliver gRPC is internal-only (container network)
SLIVER_GRPC_PORT=31337

# VNC password for managed endpoints
VNC_PASSWORD=vnc_low_pass

# ════════════════════════════════════════════
#  CTI BRIDGE
# ════════════════════════════════════════════

# Password for the CTI relay to connect to low-side PostgreSQL
CTI_LOW_PG_PASSWORD=ems_dev_password_low_change_me

# CTI relay API token (must match the token configured on the CTI relay service)
# Generate with: openssl rand -hex 32
CTI_API_TOKEN=cti_relay_shared_token_change_me_in_production

# ════════════════════════════════════════════
#  APACHE NIFI (CTI zone — shared across enclaves)
# ════════════════════════════════════════════

# NiFi web UI host port (maps to container port 8443)
NIFI_PORT=18443

# Sensitive properties encryption key (change in production)
NIFI_SENSITIVE_PROPS_KEY=ems-cop-nifi-key-change-me

# NiFi single-user credentials
NIFI_ADMIN_USER=admin
NIFI_ADMIN_PASSWORD=emsNifiAdmin123!
