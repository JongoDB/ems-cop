# EMS-COP CTI Zone — Environment Configuration
# Copy to .env.cti and fill in values before running:
#   docker compose -f docker-compose.cti.yml --env-file .env.cti up -d
#
# The CTI zone bridges low and high enclaves using Apache NiFi
# for provenance-tracked, policy-enforced data flow.

# ════════════════════════════════════════════
#  ZONE IDENTITY
# ════════════════════════════════════════════

# This is the cross-domain bridge zone — NOT an enclave
# ENCLAVE=cti

# ════════════════════════════════════════════
#  CTI RELAY SERVICE
# ════════════════════════════════════════════

# API token shared between CTI relay and both enclaves
# Generate with: openssl rand -hex 32
# IMPORTANT: Must match CTI_API_TOKEN on both low and high enclaves
CTI_API_TOKEN=cti_relay_shared_token_change_me_in_production

# CTI relay service port
CTI_RELAY_PORT=3010

# ════════════════════════════════════════════
#  APACHE NIFI
# ════════════════════════════════════════════

# NiFi web UI host port (maps to container port 8443)
NIFI_PORT=18443

# Sensitive properties encryption key
# Generate with: openssl rand -hex 16
# IMPORTANT: Changing this after deployment will invalidate encrypted flow data
NIFI_SENSITIVE_PROPS_KEY=ems-cop-nifi-key-change-me

# NiFi single-user credentials
# IMPORTANT: Change these in production
NIFI_ADMIN_USER=admin
NIFI_ADMIN_PASSWORD=emsNifiAdmin123!

# ════════════════════════════════════════════
#  LOW-SIDE CONNECTION
# ════════════════════════════════════════════

# PostgreSQL connection to low-side (for NiFi data pulls)
CTI_LOW_PG_HOST=postgres-low
CTI_LOW_PG_PORT=5432
CTI_LOW_PG_DB=ems
CTI_LOW_PG_USER=ems_admin
CTI_LOW_PG_PASSWORD=ems_dev_password_low_change_me

# Low-side CTI relay endpoint
CTI_LOW_RELAY_URL=http://cti-relay-low:3010

# ════════════════════════════════════════════
#  HIGH-SIDE CONNECTION
# ════════════════════════════════════════════

# PostgreSQL connection to high-side (for NiFi data pushes)
CTI_HIGH_PG_HOST=postgres-high
CTI_HIGH_PG_PORT=5432
CTI_HIGH_PG_DB=ems
CTI_HIGH_PG_USER=ems_admin
CTI_HIGH_PG_PASSWORD=ems_dev_password_high_change_me

# High-side CTI relay endpoint
CTI_HIGH_RELAY_URL=http://cti-relay-high:3010

# ════════════════════════════════════════════
#  CLASSIFICATION POLICY
# ════════════════════════════════════════════

# Maximum classification level allowed to cross the CTI bridge
# SECRET data must NEVER cross — enforced at NiFi flow level
CTI_MAX_CLASSIFICATION=CUI

# Allowed classifications for cross-domain transfer
# Comma-separated: UNCLASSIFIED,CUI
CTI_ALLOWED_CLASSIFICATIONS=UNCLASSIFIED,CUI

# ════════════════════════════════════════════
#  NETWORK PORTS
# ════════════════════════════════════════════

# CTI zone does not expose EMS service ports externally
# Only NiFi web UI and CTI relay are exposed
CTI_NET_CIDR=10.102.0.0/16
