# EMS-COP High-Side Enclave — Environment Configuration
# Copy to .env.high and fill in values before running:
#   docker compose -f docker-compose.high.yml --env-file .env.high up -d

# ════════════════════════════════════════════
#  ENCLAVE IDENTITY
# ════════════════════════════════════════════

# Enclave classification level (high = SECRET / strategic)
# Set automatically in x-common-env-high, but available for override
# ENCLAVE=high

# ════════════════════════════════════════════
#  REQUIRED
# ════════════════════════════════════════════

# PostgreSQL
POSTGRES_PASSWORD=ems_dev_password_high_change_me

# JWT signing secret (generate with: openssl rand -hex 32)
# IMPORTANT: Low and high enclaves should use DIFFERENT JWT secrets
JWT_SECRET=ems_jwt_secret_high_change_me_in_production

# ════════════════════════════════════════════
#  INFRASTRUCTURE
# ════════════════════════════════════════════

# Redis
REDIS_PASSWORD=ems_redis_high_password

# ClickHouse
CLICKHOUSE_PASSWORD=ems_audit_high_password

# MinIO (S3-compatible object storage)
MINIO_ACCESS_KEY=ems_minio_high_admin
MINIO_SECRET_KEY=ems_minio_secret_high_change_me

# ════════════════════════════════════════════
#  NETWORK PORTS (host mappings — high side, offset from low)
# ════════════════════════════════════════════

# Traefik (high side — offset by +10000 from low)
EMS_HTTP_PORT=28080
EMS_HTTPS_PORT=28443
TRAEFIK_DASHBOARD_PORT=28081

# PostgreSQL dev access
PG_HOST_PORT=25432

# ClickHouse dev access
CH_HTTP_PORT=28123
CH_NATIVE_PORT=29000

# Redis dev access
REDIS_HOST_PORT=26379

# NATS dev access
NATS_HOST_PORT=24222
NATS_MON_PORT=28222

# MinIO
MINIO_API_PORT=29090
MINIO_CONSOLE_PORT=29001

# CORS allowed origins (must match Traefik host port)
ALLOWED_ORIGINS=http://localhost:28080

# ════════════════════════════════════════════
#  NOTIFICATIONS (optional)
# ════════════════════════════════════════════

# SMTP for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ems-cop-high.local

# Jira integration
JIRA_DEFAULT_URL=
JIRA_DEFAULT_EMAIL=
JIRA_DEFAULT_TOKEN=

# ════════════════════════════════════════════
#  CTI BRIDGE
# ════════════════════════════════════════════

# Password for the CTI relay to connect to high-side PostgreSQL
CTI_HIGH_PG_PASSWORD=ems_dev_password_high_change_me

# CTI relay API token (must match the token configured on the CTI relay service)
# Generate with: openssl rand -hex 32
CTI_API_TOKEN=cti_relay_shared_token_change_me_in_production

# ════════════════════════════════════════════
#  APACHE NIFI (CTI zone — shared across enclaves)
# ════════════════════════════════════════════

# NiFi web UI host port (maps to container port 8443)
# NOTE: NiFi runs in the CTI zone, typically started via docker-compose.cti.yml.
# These vars are here for reference; the CTI compose file uses its own port mapping.
NIFI_PORT=18443

# Sensitive properties encryption key (change in production)
NIFI_SENSITIVE_PROPS_KEY=ems-cop-nifi-key-change-me

# NiFi single-user credentials
NIFI_ADMIN_USER=admin
NIFI_ADMIN_PASSWORD=emsNifiAdmin123!
